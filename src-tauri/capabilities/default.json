{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:app:allow-version",
    "opener:default",
    "opener:allow-open-url",
    "store:default",
    "notification:default",
    "autostart:default"
  ]
}
